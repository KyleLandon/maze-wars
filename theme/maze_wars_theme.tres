; ─────────────────────────────────────────────────────────────────────────────
[resource]

; Panel
Panel/styles/panel = SubResource("StyleBoxFlat_panel")

; PanelContainer
PanelContainer/styles/panel = SubResource("StyleBoxFlat_panel")

; Button — primary cyan style
Button/styles/normal   = SubResource("StyleBoxFlat_btn_normal")
Button/styles/hover    = SubResource("StyleBoxFlat_btn_hover")
Button/styles/pressed  = SubResource("StyleBoxFlat_btn_pressed")
Button/styles/disabled = SubResource("StyleBoxFlat_btn_disabled")
Button/styles/focus    = SubResource("StyleBoxFlat_btn_hover")
Button/colors/font_color          = Color(0.0, 0.788, 1.0, 1.0)
Button/colors/font_hover_color    = Color(0.0, 0.788, 1.0, 1.0)
Button/colors/font_pressed_color  = Color(1.0, 1.0, 1.0, 1.0)
Button/colors/font_disabled_color = Color(0.306, 0.337, 0.415, 1.0)

; ProgressBar (HP by default — swap fill style per instance)
ProgressBar/styles/background = SubResource("StyleBoxFlat_progress_bg")
ProgressBar/styles/fill       = SubResource("StyleBoxFlat_progress_hp")
ProgressBar/colors/font_color = Color(0.91, 0.918, 0.941, 1.0)

; LineEdit
LineEdit/styles/normal        = SubResource("StyleBoxFlat_input")
LineEdit/styles/focus         = SubResource("StyleBoxFlat_input_focus")
LineEdit/colors/font_color          = Color(0.91, 0.918, 0.941, 1.0)
LineEdit/colors/font_placeholder_color = Color(0.306, 0.337, 0.415, 1.0)
LineEdit/colors/caret_color         = Color(0.0, 0.788, 1.0, 1.0)
LineEdit/colors/selection_color     = Color(0.0, 0.788, 1.0, 0.3)

; Label
Label/colors/font_color = Color(0.91, 0.918, 0.941, 1.0)

; TabContainer / TabBar
TabBar/styles/tab_selected   = SubResource("StyleBoxFlat_tab_active")
TabBar/styles/tab_unselected = SubResource("StyleBoxFlat_tab_inactive")
TabBar/styles/tab_hovered    = SubResource("StyleBoxFlat_tab_active")
TabBar/colors/font_selected_color   = Color(0.0, 0.788, 1.0, 1.0)
TabBar/colors/font_unselected_color = Color(0.604, 0.639, 0.741, 1.0)

; Separator
HSeparator/styles/separator = SubResource("StyleBoxFlat_separator")
VSeparator/styles/separator = SubResource("StyleBoxFlat_separator")

; Tooltip
TooltipPanel/styles/panel = SubResource("StyleBoxFlat_tooltip")
TooltipLabel/colors/font_color = Color(0.91, 0.918, 0.941, 1.0)

; HSlider
HSlider/styles/slider      = SubResource("StyleBoxFlat_slider_track")
HSlider/styles/grabber_area = SubResource("StyleBoxFlat_slider_fill")
