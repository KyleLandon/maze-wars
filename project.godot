; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Maze Wars"
config/version="0.1.2"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://assets/ui/mazewars_logo.png"

[autoload]

BrandColors="*res://scripts/autoload/brand_colors.gd"
BalanceConfig="*res://scripts/autoload/balance_config.gd"
GameConfig="*res://scripts/autoload/game_config.gd"
DamageNumbers="*res://scripts/autoload/damage_numbers.gd"
UIStyles="*res://scripts/autoload/ui_styles.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
GameVersion="*res://scripts/autoload/game_version.gd"
UpdateChecker="*res://scripts/autoload/update_checker.gd"

[gui]

theme/custom="res://theme/maze_wars_theme.tres"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

